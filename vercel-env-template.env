# Trendtrack.io - Vercel Environment Variables
# Plak deze variabelen in Vercel bij:
# Project > Settings > Environment Variables
#
# Zet bij alle variabelen Environment op:
# Production, Preview, Development

NEXT_PUBLIC_APP_URL=

# Clerk login
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Supabase database
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI assistant - kies Groq of OpenAI. Groq wordt eerst gebruikt als deze key bestaat.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=

# Later voor betalingen
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
